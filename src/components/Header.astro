---
import site from "../content/settings/site.json";

const helperPageFiles = import.meta.glob("../content/helper-pages/*.json", { eager: true });
const helperNavItems = Object.values(helperPageFiles)
  .map((entry: any) => entry.default)
  .filter((page) => page.visible && page.showInMenu)
  .sort((a, b) => a.order - b.order)
  .map((page) => ({
    label: page.card.title,
    href: `/hulpverleners/${page.title.slug}/`,
  }));

const navItems = site.navigation.map((item) =>
  item.href === "/hulpverleners/" ? { ...item, children: helperNavItems } : item
);
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand-link" href="/" aria-label="Life-Line-Trainingen home">
      <img src={site.logos.blue} alt={site.name} />
    </a>

    <nav class="desktop-nav" aria-label="Hoofdnavigatie">
      {
        navItems.map((item) =>
          item.children?.length ? (
            <div class="nav-item">
              <a class="nav-parent" href={item.href}>{item.label}</a>
              <div class="desktop-subnav" aria-label={`${item.label} submenu`}>
                {item.children.map((child) => <a href={child.href}>{child.label}</a>)}
              </div>
            </div>
          ) : (
            <a href={item.href}>{item.label}</a>
          )
        )
      }
    </nav>

    <a class="header-cta" href={site.headerCta.href}>{site.headerCta.label}</a>

    <details class="mobile-menu">
      <summary>Menu</summary>
      <nav aria-label="Mobiele navigatie">
        {
          navItems.map((item) => (
            <>
              <a href={item.href}>{item.label}</a>
              {item.children?.length && (
                <div class="mobile-subnav" aria-label={`${item.label} submenu`}>
                  {item.children.map((child) => <a href={child.href}>{child.label}</a>)}
                </div>
              )}
            </>
          ))
        }
        <a class="mobile-cta" href={site.headerCta.href}>{site.headerCta.label}</a>
      </nav>
    </details>
  </div>
</header>
