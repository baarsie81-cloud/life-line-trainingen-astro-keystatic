---
import BaseLayout from "../../layouts/BaseLayout.astro";

const blogFiles = import.meta.glob("../../content/blogs/*.json", { eager: true });
const blogs = Object.values(blogFiles)
  .map((entry: any) => entry.default)
  .filter((blog) => blog.visible)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const featured = blogs.find((blog) => blog.featured) || blogs[0];
const articles = blogs.filter((blog) => blog !== featured);
const categories = Array.from(new Set(blogs.map((blog) => blog.category))).sort();

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("nl-NL", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(new Date(date));
---

<BaseLayout
  title="Kennisbank | Life-Line-Trainingen"
  description="Praktische kennis, nieuws en blogs over reanimatie, EHBO, waterveiligheid en handelen in noodsituaties."
  image={featured?.image}
>
  <section class="knowledge-hero">
    <div class="container knowledge-hero-inner">
      <div>
        <p class="eyebrow">Kennisbank</p>
        <h1>Praktische kennis voor mensen die moeten handelen</h1>
        <p>
          Artikelen, inzichten en praktijklessen over reanimatie, eerste hulp, waterveiligheid en professioneel handelen
          wanneer seconden tellen.
        </p>
      </div>
      <aside>
        <strong>{blogs.length}</strong>
        <span>artikelen uit 2025 en 2026 overgenomen in de nieuwe kennisbank.</span>
      </aside>
    </div>
  </section>

  {featured && (
    <section class="section knowledge-featured" aria-labelledby="featured-article-title">
      <div class="container featured-article">
        <a class="featured-media" href={`/nieuws/${featured.title.slug}/`} aria-label={featured.title.name}>
          <img src={featured.image} alt={featured.imageAlt} loading="eager" decoding="async" />
        </a>
        <div class="featured-copy">
          <p class="eyebrow">Uitgelicht</p>
          <h2 id="featured-article-title">
            <a href={`/nieuws/${featured.title.slug}/`}>{featured.title.name}</a>
          </h2>
          <p>{featured.excerpt}</p>
          <div class="article-meta">
            <span>{formatDate(featured.date)}</span>
            <span>{featured.category}</span>
            <span>{featured.readingTime}</span>
          </div>
          <a class="button button-primary" href={`/nieuws/${featured.title.slug}/`}>Lees artikel</a>
        </div>
      </div>
    </section>
  )}

  <section class="section section-soft knowledge-index" id="articles">
    <div class="container">
      <div class="knowledge-toolbar">
        <div>
          <p class="eyebrow">Alle artikelen</p>
          <h2>Verdieping per onderwerp</h2>
        </div>
        <div class="filter-buttons" aria-label="Filter artikelen">
          <button type="button" class="is-active" data-filter="all">Alle</button>
          {categories.map((category) => <button type="button" data-filter={category}>{category}</button>)}
        </div>
      </div>

      <div class="article-grid">
        {
          articles.map((article) => (
            <article class="article-card" data-category={article.category}>
              <a class="article-card-media" href={`/nieuws/${article.title.slug}/`} aria-label={article.title.name}>
                <img src={article.image} alt={article.imageAlt} loading="lazy" decoding="async" />
              </a>
              <div class="article-card-copy">
                <div class="article-meta">
                  <span>{formatDate(article.date)}</span>
                  <span>{article.category}</span>
                </div>
                <h3>
                  <a href={`/nieuws/${article.title.slug}/`}>{article.title.name}</a>
                </h3>
                <p>{article.excerpt}</p>
                <a class="article-link" href={`/nieuws/${article.title.slug}/`}>Lees meer</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta-inner">
      <div>
        <p class="eyebrow">Training nodig?</p>
        <h2>Van kennis naar handelen in de praktijk</h2>
        <p>Wil je dit vertalen naar een training voor jouw team of organisatie? We denken graag praktisch met je mee.</p>
      </div>
      <a class="button button-light" href="/contact/">Plan een kennismaking</a>
    </div>
  </section>

  <script>
    const filterButtons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const cards = document.querySelectorAll<HTMLElement>("[data-category]");

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter || "all";
        filterButtons.forEach((item) => item.classList.toggle("is-active", item === button));
        cards.forEach((card) => {
          card.hidden = filter !== "all" && card.dataset.category !== filter;
        });
      });
    });
  </script>
</BaseLayout>
